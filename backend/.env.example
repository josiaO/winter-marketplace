# ============================================
# Django Core Settings
# ============================================
DJANGO_ENV=development  # Set to 'production' for production deployment
DEBUG=True  # Set to False in production
SECRET_KEY=your-secret-key-here  # Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# ============================================
# Allowed Hosts & Security
# ============================================
# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,smartdalali.onrender.com

# Comma-separated list of trusted origins for CSRF (include protocol)
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://smartdalali.onrender.com,https://smartdalali-frontend.onrender.com

# Comma-separated list of allowed origins for CORS (include protocol)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://smartdalali-frontend.onrender.com

# Frontend URL (used in emails and redirects)
FRONTEND_URL=http://localhost:5173

# Marketplace seller onboarding: block publishing until identity is verified (TrustScore / UserVerification).
# Set to false only for local demos without the verification flow.
# MARKETPLACE_PUBLISH_REQUIRES_IDENTITY_VERIFICATION=true

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string (Render provides this automatically)
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/smartdalali

# ============================================
# Redis Configuration
# ============================================
# Redis URL for caching and channels (Render provides this automatically)
REDIS_URL=redis://localhost:6379/0

# ============================================
# Message Encryption
# ============================================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MESSAGE_ENCRYPTION_KEY=your-encryption-key-here

# ============================================
# Firebase Admin SDK
# ============================================
# Firebase credentials as JSON string (entire service account JSON)
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project-id",...}

# ============================================
# Email Configuration
# ============================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@smartdalali.com

# SendGrid (optional, if using SendGrid instead of SMTP)
SENDGRID_API_KEY=your-sendgrid-api-key

# ============================================
# Django Allauth Configuration
# ============================================
ACCOUNT_AUTHENTICATION_METHOD=email
ACCOUNT_EMAIL_REQUIRED=True
ACCOUNT_EMAIL_VERIFICATION=mandatory  # Use 'optional' in development
SOCIALACCOUNT_EMAIL_VERIFICATION=optional
LOGIN_REDIRECT_URL=/

# ============================================
# Social Authentication Providers
# ============================================
# Google OAuth
SOCIAL_GOOGLE_CLIENT_ID=your-google-client-id
SOCIAL_GOOGLE_SECRET=your-google-client-secret

# Facebook OAuth
SOCIAL_FACEBOOK_CLIENT_ID=your-facebook-app-id
SOCIAL_FACEBOOK_SECRET=your-facebook-app-secret

# Microsoft OAuth
SOCIAL_MICROSOFT_CLIENT_ID=your-microsoft-client-id
SOCIAL_MICROSOFT_SECRET=your-microsoft-client-secret

# Apple OAuth
SOCIAL_APPLE_CLIENT_ID=your-apple-client-id
SOCIAL_APPLE_SECRET=your-apple-client-secret

# ============================================
# AWS S3 Storage (for media files)
# ============================================
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=your-bucket-name.s3.amazonaws.com
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# ============================================
# Cloudinary Storage
# ============================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ============================================
# Google Maps API
# ============================================
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_MAPS_GEOCODE_TIMEOUT=5

# ============================================
# Payment Integrations
# ============================================
# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# M-Pesa (Daraja API)
DAR_AFFILIATE_CONSUMER_KEY=your-consumer-key
DAR_AFFILIATE_CONSUMER_SECRET=your-consumer-secret
DAR_SHORTCODE=your-shortcode
DAR_PASSKEY=your-passkey
MPESA_API_BASE=https://sandbox.safaricom.co.ke  # Use https://api.safaricom.co.ke for production
MPESA_CALLBACK_URL=https://your-domain.com/api/v1/payments/mpesa/callback/

# ============================================
# SMS Integration (Twilio)
# ============================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# Error Tracking (Sentry)
# ============================================
SENTRY_DSN=your-sentry-dsn
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0
SENTRY_SEND_DEFAULT_PII=False

# ============================================
# AI Configuration
# ============================================
AI_API_KEY=your-ai-api-key

# Groq (used by Next.js support chat API route)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant

# ============================================
# Typesense Search
# ============================================
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=your-typesense-api-key
TYPESENSE_COLLECTION=products

# ============================================
# Google Vision (SafeSearch Moderation)
# ============================================
# Service account fields loaded from env
GOOGLE_VISION_PROJECT_ID=your-gcp-project-id
GOOGLE_VISION_PRIVATE_KEY_ID=your-private-key-id
# Keep escaped \n line breaks in the private key value
GOOGLE_VISION_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_VISION_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_VISION_CLIENT_ID=your-client-id
GOOGLE_VISION_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your-service-account

# ============================================
# JWT Configuration
# ============================================
JWT_AUDIENCE=smartdalali:web
JWT_ISSUER=smartdalali
JWT_LEEWAY_SECONDS=5

# ============================================
# Trust / abuse reports (auto-suspend)
# ============================================
# Deactivate subject user after this many *distinct reporters* with open reports (pending/under_review)
TRUST_REPORT_AUTO_SUSPEND_THRESHOLD=5
TRUST_REPORT_LOOKBACK_DAYS=90
TRUST_REPORT_MIN_DESCRIPTION_LEN=10
TRUST_REPORT_MAX_DESCRIPTION_LEN=5000

# ============================================
# Security Settings (Production)
# ============================================
SECURE_SSL_REDIRECT=True  # Set to True in production
SECURE_HSTS_SECONDS=31536000  # 1 year
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
